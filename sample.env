# ╔══════════════════════════════════════════════════════════════╗
# ║           🎵 XIVASUDEV MUSIC BOT — CONFIG FILE 🎵           ║
# ║   Copy this file to .env and fill in SESSION string         ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Telegram API Credentials (from https://my.telegram.org/apps) ──────────────
API_ID=38165687
API_HASH=1d6adcf8aed67d7f981d8e6089030158

# ── Bot Token (from @BotFather) ───────────────────────────────────────────────
BOT_TOKEN=8852307164:AAHB1My-Q3KKzPDl2Dr44LoUStXhHJkNqXw

# ── Pyrogram String Session (USER account — NOT the bot) ─────────────────────
# Generate at: https://replit.com/@AsmSafone/String-Session
# OR run:  python3 genStr.py
SESSION=

# ── Sudo / Owner User IDs (space-separated) ───────────────────────────────────
SUDOERS=8192070400

# ── Force-Join Channel ────────────────────────────────────────────────────────
FORCE_JOIN_CHANNEL=@xivasudev

# ── Stream Quality: high / medium / low ──────────────────────────────────────
QUALITY=high

# ── Stream Mode: audio / video ────────────────────────────────────────────────
STREAM_MODE=audio

# ── Bot Command Prefix (space-separated) ──────────────────────────────────────
PREFIX=! /

# ── Language Code (en / hi / ar / bn / ru etc.) ──────────────────────────────
LANGUAGE=en

# ── Admins Only Mode: True = only group admins can !play ──────────────────────
ADMINS_ONLY=False

# ── Max songs per queue ────────────────────────────────────────────────────────
MAX_QUEUE_SIZE=20

# ── Render App URL (your app URL on render.com) — enables self-ping ───────────
# Example: https://xivasudev-musicbot.onrender.com
RENDER_APP_URL=

# ── Spotify (optional) ────────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
